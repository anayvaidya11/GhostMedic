{
  "expo": {
    "name": "GHOST MEDIC",
    "slug": "ghost-medic",
    "version": "0.1.0",
    "orientation": "landscape",
    "userInterfaceStyle": "dark",
    "scheme": "ghostmedic",
    "splash": {
      "backgroundColor": "#0a0f0a",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ghostmedic.app"
    },
    "android": {
      "package": "com.ghostmedic.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
